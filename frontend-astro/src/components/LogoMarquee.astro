---
import type { ClientLogo } from '../data/client-logos';

interface Props {
  description: string;
  label: string;
  logos: ClientLogo[];
  reverse?: boolean;
}

const {
  description,
  label,
  logos = [],
  reverse = false,
} = Astro.props;
---

{
  logos.length > 0 && (
    <div class="logo-marquee-group fade-up">
      <div class="logo-marquee-meta">
        <p class="logo-marquee-label">{label}</p>
        <p class="logo-marquee-description">{description}</p>
      </div>

      <div class="logo-marquee-shell">
        <div class:list={['logo-marquee-track', reverse && 'is-reverse']}>
          {logos.map((logo) => (
            <div class="logo-marquee-item">
              <img
                src={logo.src}
                alt={logo.alt}
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
          {logos.map((logo) => (
            <div class="logo-marquee-item is-clone" aria-hidden="true">
              <img
                src={logo.src}
                alt=""
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  )
}
