---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ENDPOINT_FALLBACK } from '../../lib/fallbacks';

const track = ENDPOINT_FALLBACK;
const rows = ENDPOINT_FALLBACK.endpoint_rows;
---

<BaseLayout title="Smart Endpoint Management | Cyberfyx">
  <section style="padding-top: 100px; padding-bottom: 60px;">
    <div class="container">
      <div class="grid grid-2" style="align-items: center; gap: 4rem;">
        <div class="fade-up">
          <h1 style="margin-bottom: 1.5rem;">{track.hero_title}</h1>
          <p style="font-size: 1.1rem; margin-bottom: 2rem; line-height: 1.8; color: var(--text-secondary);">{track.hero_body}</p>
        </div>
        <div class="glass-card fade-up delay-100" style="text-align: center; padding: 4rem;">
          <i class="fa-solid fa-laptop-code" style="font-size: 6rem; color: var(--accent-secondary);"></i>
        </div>
      </div>
    </div>
  </section>

  <section style="background: var(--bg-secondary);">
    <div class="container">
      <div class="section-header fade-up">
        <h2>Our <span class="text-gradient">Offerings</span></h2>
      </div>

      {rows.length > 0 ? (
        <div class="grid grid-3" style="gap: 2rem;">
          <div class="glass-card fade-up">
            <h3 style="margin-bottom: 1.5rem; text-align: center; color: var(--logo-text-primary);">Products</h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
              {rows.map(row => row.product_name).filter(Boolean).map(item => (
                <li style="padding: 1rem; border-bottom: 1px solid rgba(128, 128, 128, 0.1); color: var(--text-secondary);">{item}</li>
              ))}
            </ul>
          </div>
          <div class="glass-card fade-up delay-100">
            <h3 style="margin-bottom: 1.5rem; text-align: center; color: var(--logo-text-primary);">Solutions</h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
              {rows.map(row => row.solution_name).filter(Boolean).map(item => (
                <li style="padding: 1rem; border-bottom: 1px solid rgba(128, 128, 128, 0.1); color: var(--text-secondary);">{item}</li>
              ))}
            </ul>
          </div>
          <div class="glass-card fade-up delay-200">
            <h3 style="margin-bottom: 1.5rem; text-align: center; color: var(--logo-text-primary);">Services</h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
              {rows.map(row => row.service_name).filter(Boolean).map(item => (
                <li style="padding: 1rem; border-bottom: 1px solid rgba(128, 128, 128, 0.1); color: var(--text-secondary);">{item}</li>
              ))}
            </ul>
          </div>
        </div>
      ) : (
        <div class="glass-card fade-up" style="padding: 2rem; text-align: center;">
          <p style="margin: 0; color: var(--text-secondary);">Offerings will be updated soon.</p>
        </div>
      )}

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/services" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Back to All Services</a>
      </div>
    </div>
  </section>
</BaseLayout>
